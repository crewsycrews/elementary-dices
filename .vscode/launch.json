{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "chrome",
            "request": "launch",
            "name": "Vue: Chrome",
            "url": "http://localhost:5173",
            "webRoot": "${workspaceFolder}/client",
            "sourceMapPathOverrides": {
                "webpack:///./src/*": "${workspaceFolder}/client/src/*",
                "webpack:///./*": "${workspaceFolder}/client/*",
                "webpack:///src/*": "${workspaceFolder}/client/src/*",
                "webpack:///*": "*",
                "/./*": "${workspaceFolder}/client/*"
            }
        },
        {
            "type": "chrome",
            "request": "attach",
            "name": "Vue: Chrome (Attach)",
            "port": 9222,
            "url": "http://localhost:5173",
            "webRoot": "${workspaceFolder}/client",
            "sourceMapPathOverrides": {
                "webpack:///./src/*": "${workspaceFolder}/client/src/*",
                "webpack:///./*": "${workspaceFolder}/client/*",
                "webpack:///src/*": "${workspaceFolder}/client/src/*",
                "webpack:///*": "*",
                "/./*": "${workspaceFolder}/client/*"
            }
        }
    ]
}