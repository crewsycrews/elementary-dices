{
  "name": "elementary-dices",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "bun dev:server & bun dev:client",
    "dev:server": "bun --filter @elementary-dices/server dev",
    "dev:client": "bun --filter @elementary-dices/client dev",
    "build": "bun run --workspaces build",
    "typecheck": "bun run --workspaces --if-present typecheck",
    "test": "bun run --workspaces --if-present test"
  }
}
