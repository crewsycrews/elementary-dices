{
  "name": "@elementary-dices/server",
  "version": "1.0.0",
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "dev": "bun run --elide-lines=0 --watch index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:migrate": "knex migrate:latest --knexfile ./knexfile.ts",
    "db:migrate:make": "knex migrate:make --knexfile ./knexfile.ts",
    "db:migrate:rollback": "knex migrate:rollback --knexfile ./knexfile.ts",
    "db:migrate:clear": "knex migrate:rollback --all --knexfile ./knexfile.ts",
    "db:seed": "knex seed:run --knexfile ./knexfile.ts",
    "db:seed:make": "knex seed:make --knexfile ./knexfile.ts"
  },
  "dependencies": {
    "@elementary-dices/shared": "workspace:*",
    "@elysiajs/cors": "latest",
    "@elysiajs/jwt": "^1.4.0",
    "arctic": "^3.7.0",
    "dotenv": "latest",
    "elysia": "latest",
    "knex": "^3.1.0",
    "pg": "^8.18.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.8",
    "bun-types": "latest",
    "tsx": "^4.21.0",
    "typescript": "5.4.5"
  }
}
