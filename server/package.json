{
  "name": "@elementary-dices/server",
  "version": "1.0.0",
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "dev": "bun run --watch index.ts",
    "build": "tsc",
    "db:migrate": "tsx node_modules/.bin/knex migrate:latest --knexfile ./knexfile.ts",
    "db:migrate:make": "tsx node_modules/.bin/knex migrate:make --knexfile ./knexfile.ts",
    "db:migrate:rollback": "tsx node_modules/.bin/knex migrate:rollback --knexfile ./knexfile.ts",
    "db:seed": "tsx node_modules/.bin/knex seed:run --knexfile ./knexfile.ts",
    "db:seed:make": "tsx node_modules/.bin/knex seed:make --knexfile ./knexfile.ts"
  },
  "dependencies": {
    "@elementary-dices/shared": "workspace:*",
    "elysia": "latest",
    "knex": "^3.1.0",
    "pg": "^8.18.0",
    "@elysiajs/cors": "latest",
    "dotenv": "latest"
  },
  "devDependencies": {
    "bun-types": "latest",
    "tsx": "^4.21.0",
    "typescript": "latest"
  }
}
